---
// JS
---

<style>
  @keyframes spiral-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .hero-spiral {
    animation: spiral-spin 18s linear infinite;
    transform-origin: center;
  }

  .hero-slot {
    position: relative;
    overflow: hidden;
  }

  .hero-slot img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.9s ease-in-out;
  }

  .hero-slot img.active {
    opacity: 1;
  }
</style>

<div class="flex flex-col gap-7">
  <div class="flex items-end justify-between">
    <span class="text-[104px] leading-[104px] tracking-[-3.12px]">We are</span>
    <img src="/images/hero/hero-image-one.svg" class="hero-spiral" />
    <span class="text-[104px] leading-[104px] tracking-[-3.12px]">MojoTech's</span>

    <!-- Top-right slot: 3 photo states -->
    <div class="hero-slot" style="width: 155px; height: 232px;">
      <img src="/images/hero/hero-image-two.jpg" data-state="0" class="active" alt="" />
      <img src="/images/hero/hero-image-two-s2.jpg" data-state="1" alt="" />
      <img src="/images/hero/hero-image-two-s3.jpg" data-state="2" alt="" />
    </div>
  </div>

  <div class="flex items-start gap-6">
    <!-- Bottom-left slot: 3 photo states -->
    <div class="hero-slot" style="width: 334px; height: 188px;">
      <img src="/images/hero/hero-image-three.jpg" data-state="0" class="active" alt="" />
      <img src="/images/hero/hero-image-three-s2.jpg" data-state="1" alt="" />
      <img src="/images/hero/hero-image-three-s3.jpg" data-state="2" alt="" />
    </div>

    <span class="text-[104px] leading-[104px] tracking-[-3.12px]">design</span>

    <img
      srcset="/images/hero/hero-image-four.jpg 480w, /images/hero/hero-image-four@2x.jpg 800w"
      sizes="(max-width: 600px) 480px, 800px"
      src="/images/hero/hero-image-four.jpg"
      class="max-h-[233px]"
    />

    <span class="text-[104px] leading-[104px] tracking-[-3.12px]">team.</span>
  </div>
</div>

<script>
  const STATES = 3;
  const INTERVAL_MS = 4000;
  let current = 0;

  function advance() {
    current = (current + 1) % STATES;
    document.querySelectorAll<HTMLImageElement>('.hero-slot img').forEach(img => {
      const active = parseInt(img.dataset.state ?? '0') === current;
      img.classList.toggle('active', active);
    });
  }

  setInterval(advance, INTERVAL_MS);
</script>
